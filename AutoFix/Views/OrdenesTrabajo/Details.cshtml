@model AutoFix.Entities.OrdenTrabajo

@{
    ViewBag.Title = "Detalle de Orden de Trabajo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="card shadow-sm">

        <div class="card-header bg-info text-white">
            <h4 class="mb-0">Detalle de Orden de Trabajo</h4>
        </div>

        <div class="card-body">

            <dl class="row">

                <dt class="col-sm-3">Vehículo</dt>
                <dd class="col-sm-9">
                    @if (Model.Vehiculo != null)
                    {
                        <span>@Model.Vehiculo.Placa - @Model.Vehiculo.Marca @Model.Vehiculo.Modelo</span>
                    }
                    else
                    {
                        <span class="text-muted">Sin vehículo asociado</span>
                    }
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.DescripcionTrabajo)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.DescripcionTrabajo)
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.Estado)
                </dt>
                <dd class="col-sm-9">
                    @if (Model.Estado == "Pendiente")
                    {
                        <span class="badge bg-warning text-dark">Pendiente</span>
                    }
                    else if (Model.Estado == "En Proceso")
                    {
                        <span class="badge bg-primary">En Proceso</span>
                    }
                    else if (Model.Estado == "Finalizada")
                    {
                        <span class="badge bg-success">Finalizada</span>
                    }
                    else if (Model.Estado == "Cancelada")
                    {
                        <span class="badge bg-danger">Cancelada</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@Model.Estado</span>
                    }
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.FechaCreacion)
                </dt>
                <dd class="col-sm-9">
                    @Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.FechaFinalizacion)
                </dt>
                <dd class="col-sm-9">
                    @if (Model.FechaFinalizacion.HasValue)
                    {
                        @Model.FechaFinalizacion.Value.ToString("dd/MM/yyyy HH:mm")
                    }
                    else
                    {
                        <span class="text-muted">Pendiente</span>
                    }
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.Observaciones)
                </dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrWhiteSpace(Model.Observaciones))
                    {
                        @Model.Observaciones
                    }
                    else
                    {
                        <span class="text-muted">Sin observaciones</span>
                    }
                </dd>

            </dl>

            <hr />

            <div class="d-flex justify-content-between">
                @Html.ActionLink("Volver", "Index", null, new { @class = "btn btn-secondary" })

                @Html.ActionLink("Editar", "Edit", new { id = Model.Id }, new { @class = "btn btn-warning" })
            </div>

        </div>

    </div>

</div>