@{
    ViewBag.Title = "Iniciar Sesión";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-dark text-white text-center">
                    <h4><i class="fas fa-sign-in-alt"></i> Iniciar Sesión</h4>
                </div>
                <div class="card-body">

                    @if (TempData["MensajeExito"] != null)
                    {
                        <div class="alert alert-success">
                            @TempData["MensajeExito"]
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(ViewBag.Error))
                    {
                        <div class="alert alert-danger">
                            @ViewBag.Error
                        </div>
                    }

                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()

                        <div class="form-group mb-3">
                            <label for="correo" class="font-weight-bold">Correo Electrónico</label>
                            <input type="email" name="correo" id="correo" class="form-control" placeholder="correo@ejemplo.com" required />
                        </div>

                        <div class="form-group mb-3">
                            <label for="contraseña" class="font-weight-bold">Contraseña</label>
                            <input type="password" name="contraseña" id="contraseña" class="form-control" placeholder="Ingrese su contraseña" required />
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-sign-in-alt"></i> Ingresar
                            </button>
                        </div>
                    }

                    <hr />
                    <p class="text-center">
                        ¿No tiene cuenta? <a href="@Url.Action("Create", "Clientes")">Regístrese aquí</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>