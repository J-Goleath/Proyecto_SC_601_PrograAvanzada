@model IEnumerable<AutoFix.Entities.Notificacion>

@{
    ViewBag.Title = "Mis Notificaciones";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    @if (TempData["MensajeExito"] != null)
    {
        <div id="mensajeExito" class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["MensajeExito"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <div class="card shadow">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Mis Notificaciones</h4>
            @if (Model.Any(n => !n.Leida))
            {
                <form action="@Url.Action("MarcarTodasLeidas", "Notificaciones")" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-light btn-sm">Marcar todas como leídas</button>
                </form>
            }
        </div>
        <div class="card-body">

            @if (!Model.Any())
            {
                <div class="alert alert-info">
                    No tiene notificaciones por el momento.
                </div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var item in Model)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center flex-wrap @(item.Leida ? "" : "list-group-item-warning")">
                            <div>
                                <p class="mb-1">@item.Mensaje</p>
                                <small class="text-muted">@item.FechaEnvio.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                            <div>
                                @if (!item.Leida)
                                {
                                    <form action="@Url.Action("MarcarLeida", "Notificaciones")" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-outline-secondary btn-sm">Marcar como leída</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">Leída</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<script>
    function desplegarMensaje(nombreMensaje) {
        const mensaje = document.getElementById(nombreMensaje);
        if (mensaje) {
            mensaje.style.transition = "opacity 1.5s";
            setTimeout(function () {
                mensaje.style.opacity = "0";
                mensaje.remove();
            }, 3000);
        }
    }
    desplegarMensaje("mensajeExito");
</script>
