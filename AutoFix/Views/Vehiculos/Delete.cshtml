@model AutoFix.Entities.Vehiculo

@{
    ViewBag.Title = "Eliminar Vehículo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-danger text-white">
            <h4>Confirmar Eliminación</h4>
        </div>
        <div class="card-body">
            <div class="alert alert-warning">
                <strong>¿Está seguro de eliminar este vehículo?</strong>
                <p>Esta acción no se puede deshacer.</p>
            </div>

            <dl class="row">
                <dt class="col-sm-3">Placa</dt>
                <dd class="col-sm-9">@Model.Placa</dd>

                <dt class="col-sm-3">Marca</dt>
                <dd class="col-sm-9">@Model.Marca</dd>

                <dt class="col-sm-3">Modelo</dt>
                <dd class="col-sm-9">@Model.Modelo</dd>

                <dt class="col-sm-3">Cliente</dt>
                <dd class="col-sm-9">@(Model.Cliente != null ? Model.Cliente.Nombre : "Sin cliente")</dd>
            </dl>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(model => model.Id)

                <div class="form-group mt-3">
                    <button type="submit" class="btn btn-danger">Eliminar</button>
                    @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-secondary" })
                </div>
            }
        </div>
    </div>
</div>