@model IEnumerable<AutoFix.Entities.CitaSolicitud>

@{
    ViewBag.Title = "Asignación de Citas";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var mecanicos = ViewBag.Mecanicos as List<AutoFix.Entities.Cliente>;
}

<div class="container mt-4">

    @if (TempData["MensajeExito"] != null)
    {
        <div id="mensajeExito" class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["MensajeExito"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    @if (TempData["MensajeError"] != null)
    {
        <div id="mensajeError" class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["MensajeError"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <div class="card shadow">
        <div class="card-header bg-dark text-white">
            <h4>Asignación de Mecánicos a Citas</h4>
        </div>
        <div class="card-body">

            <table class="table table-bordered table-striped table-hover">
                <thead class="thead-dark">
                    <tr>
                        <th>Cliente</th>
                        <th>Vehículo</th>
                        <th>Fecha</th>
                        <th>Hora</th>
                        <th>Descripción</th>
                        <th>Estado</th>
                        <th>Mecánico</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@(item.Vehiculo != null && item.Vehiculo.Cliente != null ? item.Vehiculo.Cliente.Nombre : "N/A")</td>
                            <td>@(item.Vehiculo != null ? item.Vehiculo.Placa + " - " + item.Vehiculo.Marca : "N/A")</td>
                            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>@item.Hora.ToString(@"hh\:mm")</td>
                            <td>@item.DescripcionFallos</td>
                            <td>
                                @if (item.Procesada)
                                {
                                    <span class="badge badge-success">Asignada</span>
                                }
                                else
                                {
                                    <span class="badge badge-warning">Pendiente</span>
                                }
                            </td>
                            <td>
                                @if (item.Procesada && item.Mecanico != null)
                                {
                                    @item.Mecanico.Nombre
                                }
                                else
                                {
                                    <span class="text-muted">Sin asignar</span>
                                }
                            </td>
                            <td>
                                @if (!item.Procesada)
                                {
                                    <form action="@Url.Action("AsignarMecanico", "AsignacionCitas")" method="post" style="display:inline-flex; gap:4px;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="citaId" value="@item.Id" />
                                        <select name="mecanicoId" class="form-control form-control-sm" required style="width:auto;">
                                            <option value="">Seleccione mecánico</option>
                                            @if (mecanicos != null)
                                            {
                                                foreach (var mec in mecanicos)
                                                {
                                                    <option value="@mec.Id">@mec.Nombre</option>
                                                }
                                            }
                                        </select>
                                        <button type="submit" class="btn btn-primary btn-sm">Asignar</button>
                                    </form>
                                }
                                else
                                {
                                    <form action="@Url.Action("QuitarAsignacion", "AsignacionCitas")" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="citaId" value="@item.Id" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('¿Quitar la asignación de mecánico?')">
                                            Quitar asignación
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!Model.Any())
            {
                <div class="alert alert-info">
                    No hay citas registradas.
                </div>
            }
        </div>
    </div>
</div>

<script>
    function desplegarMensaje(nombreMensaje) {
        const mensaje = document.getElementById(nombreMensaje);
        if (mensaje) {
            mensaje.style.transition = "opacity 1.5s";
            setTimeout(function () {
                mensaje.style.opacity = "0";
                mensaje.remove();
            }, 3000);
        }
    }
    desplegarMensaje("mensajeExito");
    desplegarMensaje("mensajeError");
</script>
