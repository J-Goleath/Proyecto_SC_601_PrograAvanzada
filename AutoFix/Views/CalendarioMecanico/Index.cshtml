@model IEnumerable<AutoFix.Entities.CitaSolicitud>

@{
    ViewBag.Title = "Mis Citas Asignadas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    @if (TempData["MensajeExito"] != null)
    {
        <div id="mensajeExito" class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["MensajeExito"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <div class="card shadow">
        <div class="card-header bg-dark text-white">
            <h4>Mis Citas Asignadas</h4>
        </div>
        <div class="card-body">

            @if (!Model.Any())
            {
                <div class="alert alert-info">
                    No tiene citas asignadas por el momento.
                </div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var item in Model)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center flex-wrap">
                            <div>
                                <strong>
                                    @(item.Vehiculo != null ? item.Vehiculo.Placa + " - " + item.Vehiculo.Marca + " " + item.Vehiculo.Modelo : "N/A")
                                </strong>
                                <br />
                                <span class="text-muted">@item.DescripcionFallos</span>
                                <br />
                                <span class="text-muted">
                                    Cliente: @(item.Vehiculo != null && item.Vehiculo.Cliente != null ? item.Vehiculo.Cliente.Nombre : "N/A")
                                </span>
                            </div>
                            <div class="text-right">
                                <div>@item.Fecha.ToString("dd/MM/yyyy")</div>
                                <div class="text-muted">@item.Hora.ToString(@"hh\:mm")</div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<script>
    function desplegarMensaje(nombreMensaje) {
        const mensaje = document.getElementById(nombreMensaje);
        if (mensaje) {
            mensaje.style.transition = "opacity 1.5s";
            setTimeout(function () {
                mensaje.style.opacity = "0";
                mensaje.remove();
            }, 3000);
        }
    }
    desplegarMensaje("mensajeExito");
</script>
